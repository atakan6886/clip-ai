def with_retry(fn: Callable, retries: int = 2, delay: float = 2.0,
               error_cls: type = AppError, context: str = "") -> any:
    """
    Ð’Ñ‹Ð¿Ð¾Ð»Ð½ÑÐµÑ‚ fn Ñ Ð¿Ð¾Ð²Ñ‚Ð¾Ñ€Ð½Ñ‹Ð¼Ð¸ Ð¿Ð¾Ð¿Ñ‹Ñ‚ÐºÐ°Ð¼Ð¸ Ð¿Ñ€Ð¸ Ð¾ÑˆÐ¸Ð±ÐºÐµ.
    retries â€” ÑÐºÐ¾Ð»ÑŒÐºÐ¾ Ñ€Ð°Ð· Ð¿Ð¾Ð²Ñ‚Ð¾Ñ€Ð¸Ñ‚ÑŒ Ð¿Ð¾ÑÐ»Ðµ Ð¿ÐµÑ€Ð²Ð¾Ð¹ Ð½ÐµÑƒÐ´Ð°Ñ‡Ð¸.
    delay   â€” Ð¿Ð°ÑƒÐ·Ð° Ð¼ÐµÐ¶Ð´Ñƒ Ð¿Ð¾Ð¿Ñ‹Ñ‚ÐºÐ°Ð¼Ð¸ Ð² ÑÐµÐºÑƒÐ½Ð´Ð°Ñ….
    Ð‘Ñ€Ð¾ÑÐ°ÐµÑ‚ Ð¿Ð¾ÑÐ»ÐµÐ´Ð½ÐµÐµ Ð¸ÑÐºÐ»ÑŽÑ‡ÐµÐ½Ð¸Ðµ ÐµÑÐ»Ð¸ Ð²ÑÐµ Ð¿Ð¾Ð¿Ñ‹Ñ‚ÐºÐ¸ Ð¿Ñ€Ð¾Ð²Ð°Ð»Ð¸Ð»Ð¸ÑÑŒ.
    """
    last_exc = None
    for attempt in range(1, retries + 2):  # +2 = Ð¿ÐµÑ€Ð²Ð°Ñ Ð¿Ð¾Ð¿Ñ‹Ñ‚ÐºÐ° + retries
        try:
            return fn()
        except Exception as e:
            last_exc = e
            if attempt <= retries:
                logger.warning(f"[{context}] ÐŸÐ¾Ð¿Ñ‹Ñ‚ÐºÐ° {attempt} Ð½Ðµ ÑƒÐ´Ð°Ð»Ð°ÑÑŒ: {e} â€” Ð¿Ð¾Ð²Ñ‚Ð¾Ñ€ Ñ‡ÐµÑ€ÐµÐ· {delay}Ñ")
                time.sleep(delay)
            else:
                logger.error(f"[{context}] Ð’ÑÐµ {retries + 1} Ð¿Ð¾Ð¿Ñ‹Ñ‚Ð¾Ðº Ð¿Ñ€Ð¾Ð²Ð°Ð»Ð¸Ð»Ð¸ÑÑŒ: {e}")
    raise error_cls(str(last_exc), recoverable=True)

