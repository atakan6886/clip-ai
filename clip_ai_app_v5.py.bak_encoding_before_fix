def handle_error(e: Exception, context: str, logger_inst=None, recoverable: bool = True) -> AppError:
    """
    Ð¦ÐµÐ½Ñ‚Ñ€Ð°Ð»Ð¸Ð·Ð¾Ð²Ð°Ð½Ð½Ñ‹Ð¹ Ð¾Ð±Ñ€Ð°Ð±Ð¾Ñ‚Ñ‡Ð¸Ðº â€” Ð»Ð¾Ð³Ð¸Ñ€ÑƒÐµÑ‚ Ð¸ Ð¾Ð±Ð¾Ñ€Ð°Ñ‡Ð¸Ð²Ð°ÐµÑ‚ Ð² AppError.
    Ð˜ÑÐ¿Ð¾Ð»ÑŒÐ·Ð¾Ð²Ð°Ñ‚ÑŒ Ð²ÐµÐ·Ð´Ðµ Ð²Ð¼ÐµÑÑ‚Ð¾ Ñ€Ð°Ð·Ñ€Ð¾Ð·Ð½ÐµÐ½Ð½Ñ‹Ñ… except.
    """
    log = logger_inst or logger
    if isinstance(e, AppError):
        log.error(f"[{context}] {type(e).__name__}: {e}")
        return e
    log.exception(f"[{context}] ÐÐµÐ¾Ð±Ñ€Ð°Ð±Ð¾Ñ‚Ð°Ð½Ð½Ð°Ñ Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")
    return AppError(str(e), recoverable=recoverable)

