    def _get_duration(self, video_path: str) -> float:
        """ÐŸÐ¾Ð»ÑƒÑ‡Ð°ÐµÑ‚ Ð´Ð»Ð¸Ñ‚ÐµÐ»ÑŒÐ½Ð¾ÑÑ‚ÑŒ Ð²Ð¸Ð´ÐµÐ¾ Ñ‡ÐµÑ€ÐµÐ· ffprobe Ñ Ñ‚Ð°Ð¹Ð¼Ð°ÑƒÑ‚Ð¾Ð¼."""
        try:
            res = subprocess.run(
                [FFPROBE, "-v", "quiet", "-print_format", "json", "-show_format", video_path],
                capture_output=True, text=True,
                creationflags=NO_WINDOW,
                timeout=Config.PROBE_TIMEOUT)
            info     = json.loads(res.stdout)
            duration = float(info["format"].get("duration", 0) or 0)
            logger.info(f"Ð”Ð»Ð¸Ñ‚ÐµÐ»ÑŒÐ½Ð¾ÑÑ‚ÑŒ {os.path.basename(video_path)}: {duration:.1f}Ñ")
            return duration
        except subprocess.TimeoutExpired:
