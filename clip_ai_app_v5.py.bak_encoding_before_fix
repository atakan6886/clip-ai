class GPUManager:
    """
    Ð¦ÐµÐ½Ñ‚Ñ€Ð°Ð»Ð¸Ð·Ð¾Ð²Ð°Ð½Ð½Ð¾Ðµ ÑƒÐ¿Ñ€Ð°Ð²Ð»ÐµÐ½Ð¸Ðµ GPU.
    Ð’ÑÐµ Ð¾Ð¿ÐµÑ€Ð°Ñ†Ð¸Ð¸ Ð±ÐµÐ·Ð¾Ð¿Ð°ÑÐ½Ñ‹ â€” Ð½Ð¸ÐºÐ¾Ð³Ð´Ð° Ð½Ðµ Ð¿Ð°Ð´Ð°ÑŽÑ‚, Ð²ÑÐµÐ³Ð´Ð° ÐµÑÑ‚ÑŒ fallback Ð½Ð° CPU.
    """

    def __init__(self):
        self.available    : bool = False
        self.name         : str  = "ÐÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½"
        self.vram_total   : int  = 0
        self.cuda_version : str  = ""
        self._nvml_ok     : bool = False
        self._detect()

    def _detect(self) -> None:
        """ÐžÐ¿Ñ€ÐµÐ´ÐµÐ»ÑÐµÐ¼ GPU Ð¿Ñ€Ð¸ ÑÑ‚Ð°Ñ€Ñ‚Ðµ. ÐÐ¸ÐºÐ¾Ð³Ð´Ð° Ð½Ðµ Ð±Ñ€Ð¾ÑÐ°ÐµÑ‚ Ð¸ÑÐºÐ»ÑŽÑ‡ÐµÐ½Ð¸Ðµ."""
        try:
            import torch
            if torch.cuda.is_available():
                self.available    = True
                self.name         = torch.cuda.get_device_name(0)
                props             = torch.cuda.get_device_properties(0)
                self.vram_total   = props.total_memory // (1024 * 1024)
                self.cuda_version = torch.version.cuda or ""
                logger.info(f"GPU Ð¾Ð±Ð½Ð°Ñ€ÑƒÐ¶ÐµÐ½: {self.name}, VRAM {self.vram_total}MB, CUDA {self.cuda_version}")
        except Exception as e:
            logger.debug(f"GPU (torch) Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½: {e}")

        try:
            import ctypes
            # Ð—Ð°Ð³Ñ€ÑƒÐ¶Ð°ÐµÐ¼ nvml.dll Ð½Ð°Ð¿Ñ€ÑÐ¼ÑƒÑŽ Ð¸Ð· System32 (Ñ„Ð¸ÐºÑ Ð´Ð»Ñ Windows)
            ctypes.CDLL("C:\\Windows\\System32\\nvml.dll")
            import pynvml
            pynvml.nvmlInit()
            self._nvml_ok = True
            logger.debug("pynvml Ð¸Ð½Ð¸Ñ†Ð¸Ð°Ð»Ð¸Ð·Ð¸Ñ€Ð¾Ð²Ð°Ð½ ÑƒÑÐ¿ÐµÑˆÐ½Ð¾")
        except Exception as e:
            self._nvml_ok = False
            logger.debug(f"pynvml Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½: {e}")

    def temperature(self) -> Optional[int]:
        """Ð¢ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ð° GPU Ð² Â°C. ÐŸÑ€Ð¾Ð±ÑƒÐµÑ‚ pynvml, Ð¿Ð¾Ñ‚Ð¾Ð¼ nvidia-smi."""
        # ÐŸÐ¾Ð¿Ñ‹Ñ‚ÐºÐ° Ñ‡ÐµÑ€ÐµÐ· pynvml
        if self._nvml_ok:
            try:
                import pynvml
                h = pynvml.nvmlDeviceGetHandleByIndex(0)
                return pynvml.nvmlDeviceGetTemperature(h, pynvml.NVML_TEMPERATURE_GPU)
            except Exception as e:
                logger.debug(f"pynvml temperature fallback: {e}")

        # Fallback â€” nvidia-smi Ð½Ð°Ð¿Ñ€ÑÐ¼ÑƒÑŽ
        try:
            res = subprocess.run(
                ["nvidia-smi", "--query-gpu=temperature.gpu", "--format=csv,noheader,nounits"],
                capture_output=True, text=True, timeout=3, creationflags=NO_WINDOW)
            if res.returncode == 0:
                val = res.stdout.strip()
                if val.isdigit():
                    return int(val)
        except Exception as e:
            logger.debug(f"nvidia-smi temperature Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")
        return None

    def utilization_pct(self) -> Optional[int]:
        """Ð—Ð°Ð³Ñ€ÑƒÐ·ÐºÐ° GPU Ð² Ð¿Ñ€Ð¾Ñ†ÐµÐ½Ñ‚Ð°Ñ…. ÐŸÑ€Ð¾Ð±ÑƒÐµÑ‚ pynvml, Ð¿Ð¾Ñ‚Ð¾Ð¼ nvidia-smi."""
        if self._nvml_ok:
            try:
                import pynvml
                h = pynvml.nvmlDeviceGetHandleByIndex(0)
                util = pynvml.nvmlDeviceGetUtilizationRates(h)
                val = int(getattr(util, "gpu", 0))
                return clamp(val, 0, 100)
            except Exception as e:
                logger.debug(f"pynvml utilization fallback: {e}")

        try:
            res = subprocess.run(
                ["nvidia-smi", "--query-gpu=utilization.gpu", "--format=csv,noheader,nounits"],
                capture_output=True, text=True, timeout=3, creationflags=NO_WINDOW
            )
            if res.returncode == 0:
                raw = (res.stdout or "").strip().splitlines()
                if raw:
                    txt = raw[0].strip().replace("%", "")
                    if txt.isdigit():
                        return clamp(int(txt), 0, 100)
        except Exception as e:
            logger.debug(f"nvidia-smi utilization Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")
        return None

    def vram_used_mb(self) -> Optional[int]:
        """Ð—Ð°Ð½ÑÑ‚Ñ‹Ð¹ VRAM Ð² MB. Ð¡Ð½Ð°Ñ‡Ð°Ð»Ð° pynvml, Ð¿Ð¾Ñ‚Ð¾Ð¼ torch ÐºÐ°Ðº fallback."""
        # ÐŸÐ¾Ð¿Ñ‹Ñ‚ÐºÐ° Ñ‡ÐµÑ€ÐµÐ· pynvml
        if self._nvml_ok:
            try:
                import pynvml
                h   = pynvml.nvmlDeviceGetHandleByIndex(0)
                mem = pynvml.nvmlDeviceGetMemoryInfo(h)
                return mem.used // (1024 * 1024)
            except Exception as e:
                logger.debug(f"pynvml vram_used fallback to torch: {e}")

        # Fallback â€” torch (Ð²ÑÐµÐ³Ð´Ð° Ð´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½ ÐµÑÐ»Ð¸ GPU ÐµÑÑ‚ÑŒ)
        try:
            import torch
            if torch.cuda.is_available():
                return torch.cuda.memory_allocated(0) // (1024 * 1024)
        except Exception as e:
            logger.debug(f"torch vram_used Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")
        return None

    def vram_free_mb(self) -> Optional[int]:
        """Ð¡Ð²Ð¾Ð±Ð¾Ð´Ð½Ñ‹Ð¹ VRAM Ð² MB. Ð¡Ð½Ð°Ñ‡Ð°Ð»Ð° pynvml, Ð¿Ð¾Ñ‚Ð¾Ð¼ torch ÐºÐ°Ðº fallback."""
        # ÐŸÐ¾Ð¿Ñ‹Ñ‚ÐºÐ° Ñ‡ÐµÑ€ÐµÐ· pynvml
        if self._nvml_ok:
            try:
                import pynvml
                h   = pynvml.nvmlDeviceGetHandleByIndex(0)
                mem = pynvml.nvmlDeviceGetMemoryInfo(h)
                return mem.free // (1024 * 1024)
            except Exception as e:
                logger.debug(f"pynvml vram_free fallback to torch: {e}")

        # Fallback â€” torch
        try:
            import torch
            if torch.cuda.is_available():
                total = torch.cuda.get_device_properties(0).total_memory
                used  = torch.cuda.memory_allocated(0)
                return (total - used) // (1024 * 1024)
        except Exception as e:
            logger.debug(f"torch vram_free Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")

        # ÐŸÐ¾ÑÐ»ÐµÐ´Ð½Ð¸Ð¹ fallback â€” ÐµÑÐ»Ð¸ ÑÐ¾Ð²ÑÐµÐ¼ Ð½Ð¸Ñ‡ÐµÐ³Ð¾ Ð½ÐµÑ‚, ÑÑ‡Ð¸Ñ‚Ð°ÐµÐ¼ Ñ‡Ñ‚Ð¾ 50% ÑÐ²Ð¾Ð±Ð¾Ð´Ð½Ð¾
        if self.vram_total > 0:
            logger.warning("VRAM Ð´Ð°Ð½Ð½Ñ‹Ðµ Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿Ð½Ñ‹ â€” Ð¸ÑÐ¿Ð¾Ð»ÑŒÐ·ÑƒÐµÐ¼ 50% ÐºÐ°Ðº Ð¾Ñ†ÐµÐ½ÐºÑƒ")
            return self.vram_total // 2
        return None

    def vram_pct_used(self) -> Optional[int]:
        """ÐŸÑ€Ð¾Ñ†ÐµÐ½Ñ‚ Ð·Ð°Ð½ÑÑ‚Ð¾Ð³Ð¾ VRAM. None ÐµÑÐ»Ð¸ Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿Ð½Ð¾."""
        used = self.vram_used_mb()
        if used is None or self.vram_total == 0: return None
        return int(used / self.vram_total * 100)

    def can_fit_model(self, model_mb: int, limit_pct: int) -> bool:
        """
        ÐŸÑ€Ð¾Ð²ÐµÑ€ÑÐµÑ‚ Ñ…Ð²Ð°Ñ‚Ð°ÐµÑ‚ Ð»Ð¸ VRAM Ð´Ð»Ñ Ð·Ð°Ð³Ñ€ÑƒÐ·ÐºÐ¸ Ð¼Ð¾Ð´ÐµÐ»Ð¸ Ñ ÑƒÑ‡Ñ‘Ñ‚Ð¾Ð¼ Ð»Ð¸Ð¼Ð¸Ñ‚Ð°.
        Ð•ÑÐ»Ð¸ Ð´Ð°Ð½Ð½Ñ‹Ðµ Ð¾ VRAM Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿Ð½Ñ‹ â€” Ñ€Ð°Ð·Ñ€ÐµÑˆÐ°ÐµÐ¼ GPU (Ð½Ðµ Ð±Ð»Ð¾ÐºÐ¸Ñ€ÑƒÐµÐ¼ Ð·Ñ€Ñ).
        """
        if not self.available or self.vram_total == 0: return False
        free = self.vram_free_mb()
        if free is None:
            # Ð”Ð°Ð½Ð½Ñ‹Ñ… Ð½ÐµÑ‚ â€” Ð½Ðµ Ð±Ð»Ð¾ÐºÐ¸Ñ€ÑƒÐµÐ¼ GPU, Ð»ÑƒÑ‡ÑˆÐµ Ð¿Ð¾Ð¿Ñ€Ð¾Ð±Ð¾Ð²Ð°Ñ‚ÑŒ Ð¸ Ð¿Ð¾Ð¹Ð¼Ð°Ñ‚ÑŒ Ð¾ÑˆÐ¸Ð±ÐºÑƒ
            logger.warning(f"can_fit_model: VRAM Ð´Ð°Ð½Ð½Ñ‹Ðµ Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿Ð½Ñ‹ â†’ Ñ€Ð°Ð·Ñ€ÐµÑˆÐ°ÐµÐ¼ GPU Ð´Ð»Ñ {model_mb}MB")
            return True
        allowed_mb = int(self.vram_total * limit_pct / 100)
        used       = self.vram_used_mb() or 0
        result     = (used + model_mb) <= allowed_mb
        logger.debug(f"can_fit_model({model_mb}MB): used={used}MB, allowed={allowed_mb}MB â†’ {result}")
        return result

    def clear_vram(self) -> None:
        """ÐŸÑ€Ð¸Ð½ÑƒÐ´Ð¸Ñ‚ÐµÐ»ÑŒÐ½Ð°Ñ Ð¾Ñ‡Ð¸ÑÑ‚ÐºÐ° VRAM ÐºÑÑˆÐ° PyTorch."""
        try:
