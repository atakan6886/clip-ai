    def _wait_for_cool(self, get_temp_fn: Callable, limit: int, name: str, timeout: int = Config.TEMP_TIMEOUT) -> None:
        """
        Ð£Ð½Ð¸Ð²ÐµÑ€ÑÐ°Ð»ÑŒÐ½Ð¾Ðµ Ð¾Ð¶Ð¸Ð´Ð°Ð½Ð¸Ðµ Ð¾Ñ…Ð»Ð°Ð¶Ð´ÐµÐ½Ð¸Ñ Ñ Ñ‚Ð°Ð¹Ð¼Ð°ÑƒÑ‚Ð¾Ð¼.
        timeout â€” Ð¼Ð°ÐºÑÐ¸Ð¼ÑƒÐ¼ ÑÐµÐºÑƒÐ½Ð´ Ð¾Ð¶Ð¸Ð´Ð°Ð½Ð¸Ñ (Ð´ÐµÑ„Ð¾Ð»Ñ‚ 5 Ð¼Ð¸Ð½ÑƒÑ‚).
        Ð•ÑÐ»Ð¸ Ð´Ð°Ñ‚Ñ‡Ð¸Ðº Ð·Ð°Ð²Ð¸Ñ Ð¸Ð»Ð¸ Ñ‚Ð°Ð¹Ð¼Ð°ÑƒÑ‚ Ð¸ÑÑ‚Ñ‘Ðº â€” Ð¿Ñ€Ð¾ÑÑ‚Ð¾ Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶Ð°ÐµÐ¼.
        """
        if self.stop_flag.is_set():
            return
        cool_target = limit - Config.TEMP_COOLDOWN
        start = time.time()
        while time.time() - start < timeout:
            if self.stop_flag.is_set():
                return
            if not self._wait_if_paused():
                return
            time.sleep(3)
            try:
                t = get_temp_fn()
            except Exception as e:
                logger.warning(f"Ð”Ð°Ñ‚Ñ‡Ð¸Ðº {name} ÑƒÐ¿Ð°Ð»: {e} â€” Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶Ð°ÐµÐ¼")
                break
            if t is None or t <= cool_target:
                msg = f"âœ… {name} Ð¾ÑÑ‚Ñ‹Ð» Ð´Ð¾ {t}Â°C â€” Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶Ð°ÐµÐ¼"
                self._safe_log(msg, "success")
                logger.info(msg)
                return
            msg = f"ï¸ Ð–Ð´Ñƒ... {name} {t}Â°C (Ñ†ÐµÐ»ÑŒ â‰¤ {cool_target}Â°C)"
            self._safe_log(msg, "warn")
            logger.info(msg)
        msg = f"âš ï¸ {name} Ñ‚Ð°Ð¹Ð¼Ð°ÑƒÑ‚ Ð¾Ñ…Ð»Ð°Ð¶Ð´ÐµÐ½Ð¸Ñ ({timeout}Ñ) â€” Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶Ð°ÐµÐ¼ Ð¿Ñ€Ð¸Ð½ÑƒÐ´Ð¸Ñ‚ÐµÐ»ÑŒÐ½Ð¾"
        self._safe_log(msg, "warn")
        logger.warning(msg)

    def _check_and_wait_temp(self) -> None:
        """
        ÐŸÑ€Ð¾Ð²ÐµÑ€ÑÐµÐ¼ Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ñƒ GPU Ð¸ CPU.
        Ð•ÑÐ»Ð¸ Ð¿Ñ€ÐµÐ²Ñ‹ÑˆÐµÐ½ Ð¿Ð¾Ñ€Ð¾Ð³ â€” Ð¶Ð´Ñ‘Ð¼ Ð¾Ñ…Ð»Ð°Ð¶Ð´ÐµÐ½Ð¸Ñ (Ð¼Ð°ÐºÑÐ¸Ð¼ÑƒÐ¼ 5 Ð¼Ð¸Ð½ÑƒÑ‚).
        Ð•ÑÐ»Ð¸ Ð´Ð°Ñ‚Ñ‡Ð¸Ðº Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ñ‹ GPU Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½ â€” Ð¸ÑÐ¿Ð¾Ð»ÑŒÐ·ÑƒÐµÐ¼ fallback Ð¿Ð¾ Ð·Ð°Ð³Ñ€ÑƒÐ·ÐºÐµ GPU.
        Ð’Ñ‹Ð·Ñ‹Ð²Ð°ÐµÑ‚ÑÑ Ð¸Ð· Ñ€Ð°Ð±Ð¾Ñ‡ÐµÐ³Ð¾ Ð¿Ð¾Ñ‚Ð¾ÐºÐ° â€” Ð½Ðµ Ð±Ð»Ð¾ÐºÐ¸Ñ€ÑƒÐµÑ‚ UI.
        """
        if self.stop_flag.is_set():
            return

        # ÐŸÑ€Ð¾Ð²ÐµÑ€ÐºÐ° GPU
        try:
            gpu_temp  = GPU.temperature()
            gpu_limit = self.temp_gpu_max.get()
            if gpu_temp is not None and gpu_temp >= gpu_limit:
                msg = f"ï¸ GPU {gpu_temp}Â°C â‰¥ {gpu_limit}Â°C â€” Ð¿Ð°ÑƒÐ·Ð° Ð´Ð»Ñ Ð¾Ñ…Ð»Ð°Ð¶Ð´ÐµÐ½Ð¸Ñ..."
                self._safe_log(msg, "warn")
                logger.warning(msg)
                self._wait_for_cool(GPU.temperature, gpu_limit, "GPU")
            elif gpu_temp is None and GPU.available and bool(self.use_gpu.get()):
                if not self._warned_no_gpu_temp_sensor:
                    self._warned_no_gpu_temp_sensor = True
                    msg = ("âš ï¸ Ð”Ð°Ñ‚Ñ‡Ð¸Ðº Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ñ‹ GPU Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½ â€” "
                           "Ð¸ÑÐ¿Ð¾Ð»ÑŒÐ·ÑƒÑŽ Ð¾Ð³Ñ€Ð°Ð½Ð¸Ñ‡ÐµÐ½Ð¸Ðµ Ð¿Ð¾ Ð·Ð°Ð³Ñ€ÑƒÐ·ÐºÐµ GPU")
                    self._safe_log(msg, "warn")
                    logger.warning(msg)
                self.control_gpu_load(max_gpu=self._gpu_load_limit_by_temp_setting())
        except Exception as e:
            logger.debug(f"ÐžÑˆÐ¸Ð±ÐºÐ° Ð¿Ñ€Ð¾Ð²ÐµÑ€ÐºÐ¸ Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ñ‹ GPU: {e}")

        # ÐŸÑ€Ð¾Ð²ÐµÑ€ÐºÐ° CPU
        try:
            cpu_limit = self.temp_cpu_max.get()
            cpu_temp = self._read_cpu_temp()
            if cpu_temp is None:
                if not self._warned_no_cpu_temp_sensor:
                    self._warned_no_cpu_temp_sensor = True
                    msg = ("âš ï¸ Ð”Ð°Ñ‚Ñ‡Ð¸Ðº Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ñ‹ CPU Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½ â€” "
                           "Ð¸ÑÐ¿Ð¾Ð»ÑŒÐ·ÑƒÑŽ Ð¾Ð³Ñ€Ð°Ð½Ð¸Ñ‡ÐµÐ½Ð¸Ðµ Ð¿Ð¾ Ð·Ð°Ð³Ñ€ÑƒÐ·ÐºÐµ CPU")
                    self._safe_log(msg, "warn")
                    logger.warning(msg)
                self.control_load(max_cpu=self._cpu_load_limit_by_temp_setting())
                return
            if cpu_temp >= cpu_limit:
                msg = f"ï¸ CPU {cpu_temp:.0f}Â°C â‰¥ {cpu_limit}Â°C â€” Ð¿Ð°ÑƒÐ·Ð°..."
                self._safe_log(msg, "warn")
                logger.warning(msg)
                self._wait_for_cool(self._read_cpu_temp, cpu_limit, "CPU")
        except Exception as e:
            logger.debug(f"ÐžÑˆÐ¸Ð±ÐºÐ° Ð¿Ñ€Ð¾Ð²ÐµÑ€ÐºÐ¸ Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ñ‹ CPU: {e}")

    def control_load(self, max_cpu: int = 75) -> None:
        """
        Ð•Ð”Ð˜ÐÐÐ¯ ÑÐ¸ÑÑ‚ÐµÐ¼Ð° ÐºÐ¾Ð½Ñ‚Ñ€Ð¾Ð»Ñ Ð½Ð°Ð³Ñ€ÑƒÐ·ÐºÐ¸ â€” Ð·Ð°Ð¼ÐµÐ½ÑÐµÑ‚ Ð²ÑÐµ _throttle Ð²Ñ‹Ð·Ð¾Ð²Ñ‹.
        ÐÐ´Ð°Ð¿Ñ‚Ð¸Ð²Ð½Ð°Ñ: ÐµÑÐ»Ð¸ CPU < 60% â€” Ð½Ðµ Ð¶Ð´Ñ‘Ð¼, ÐµÑÐ»Ð¸ > 80% â€” Ð¶Ð´Ñ‘Ð¼ Ð´Ð¾Ð»ÑŒÑˆÐµ.
        Ð˜ÑÐ¿Ð¾Ð»ÑŒÐ·Ð¾Ð²Ð°Ñ‚ÑŒ Ð²ÐµÐ·Ð´Ðµ Ð²Ð¼ÐµÑÑ‚Ð¾ _throttle().
        """
        if self.stop_flag.is_set():
            return
        max_cpu = int(clamp(max_cpu, 35, 95))
        max_cpu = min(max_cpu, self._cpu_load_limit_by_temp_setting())
        try:
            import psutil
            # Ð§Ð¸Ñ‚Ð°ÐµÐ¼ Ñ€ÐµÐ°Ð»ÑŒÐ½Ñ‹Ð¹ CPU
            cpu = psutil.cpu_percent(interval=0.4)
            soft_limit = max(25, max_cpu - 10)

            if cpu <= soft_limit:
                # ÐÐ°Ð³Ñ€ÑƒÐ·ÐºÐ° Ð½Ð¸Ð·ÐºÐ°Ñ â€” Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶Ð°ÐµÐ¼
                return
            if cpu <= max_cpu:
                # ÐÐ°Ð³Ñ€ÑƒÐ·ÐºÐ° Ð±Ð»Ð¸Ð·ÐºÐ° Ðº Ð»Ð¸Ð¼Ð¸Ñ‚Ñƒ â€” ÐºÐ¾Ñ€Ð¾Ñ‚ÐºÐ°Ñ Ð¿Ð°ÑƒÐ·Ð°
                if not self._wait_if_paused():
                    return
                time.sleep(0.2)
                return

            # Ð’Ñ‹ÑÐ¾ÐºÐ°Ñ Ð½Ð°Ð³Ñ€ÑƒÐ·ÐºÐ° â€” Ð¶Ð´Ñ‘Ð¼ Ð¿Ð¾ÐºÐ° Ð½Ðµ ÑƒÐ¿Ð°Ð´Ñ‘Ñ‚ Ð½Ð¸Ð¶Ðµ max_cpu
            logger.debug(f"control_load: CPU {cpu:.0f}% > {max_cpu}% â€” Ð¶Ð´Ñƒ...")
            deadline = time.time() + 30  # Ð¼Ð°ÐºÑÐ¸Ð¼ÑƒÐ¼ 30 ÑÐµÐºÑƒÐ½Ð´ Ð¶Ð´Ñ‘Ð¼
            while time.time() < deadline:
                if self.stop_flag.is_set():
                    return
                if not self._wait_if_paused():
                    return
                time.sleep(0.2)
                cpu = psutil.cpu_percent(interval=0.4)
                if cpu <= max_cpu:
                    break
        except ImportError:
            # psutil Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½ â€” Ð±Ð°Ð·Ð¾Ð²Ð°Ñ Ð¿Ð°ÑƒÐ·Ð°
            time.sleep(0.3)
        except Exception as e:
            logger.debug(f"control_load Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")
            time.sleep(0.3)

    def control_gpu_load(self, max_gpu: int = 75) -> None:
        """
        ÐœÑÐ³ÐºÐ¸Ð¹ runtime-Ð»Ð¸Ð¼Ð¸Ñ‚ÐµÑ€ Ð¿Ð¾ Ð·Ð°Ð³Ñ€ÑƒÐ·ÐºÐµ GPU (fallback, ÐºÐ¾Ð³Ð´Ð° Ð½ÐµÑ‚ Ð´Ð°Ñ‚Ñ‡Ð¸ÐºÐ° Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ñ‹ GPU).
        ÐÐµ Ð±Ð»Ð¾ÐºÐ¸Ñ€ÑƒÐµÑ‚ Ð½Ð°Ð´Ð¾Ð»Ð³Ð¾: Ð¶Ð´Ñ‘Ñ‚ Ð¼Ð°ÐºÑÐ¸Ð¼ÑƒÐ¼ Ð¾ÐºÐ¾Ð»Ð¾ 20 ÑÐµÐºÑƒÐ½Ð´.
        """
        if self.stop_flag.is_set():
            return
        if not GPU.available or not bool(self.use_gpu.get()):
            return
        max_gpu = int(clamp(max_gpu, 40, 95))
        try:
            util = GPU.utilization_pct()
            if util is None or util <= max_gpu:
                return
            logger.debug(f"control_gpu_load: GPU {util:.0f}% > {max_gpu}% â€” Ð¶Ð´Ñƒ...")
            deadline = time.time() + 20
            while time.time() < deadline:
                if self.stop_flag.is_set():
                    return
                if not self._wait_if_paused():
                    return
                time.sleep(0.25)
                util = GPU.utilization_pct()
                if util is None or util <= max_gpu:
                    return
        except Exception as e:
            logger.debug(f"control_gpu_load Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")

    def _throttle(self):
        """ÐžÐ±Ñ‘Ñ€Ñ‚ÐºÐ° Ð´Ð»Ñ ÑÐ¾Ð²Ð¼ÐµÑÑ‚Ð¸Ð¼Ð¾ÑÑ‚Ð¸ â€” Ð²Ñ‹Ð·Ñ‹Ð²Ð°ÐµÑ‚ control_load."""
        self.control_load(max_cpu=self._cpu_load_limit_by_temp_setting())

