        if r is None:
            self._safe_log("  âš ï¸ FFmpeg: ÐºÐ»Ð¸Ð¿ Ð¿Ñ€Ð¾Ð¿ÑƒÑ‰ÐµÐ½ Ð¿Ð¾ÑÐ»Ðµ Ð¾ÑˆÐ¸Ð±ÐºÐ¸/Ñ‚Ð°Ð¹Ð¼Ð°ÑƒÑ‚Ð°", "error")

