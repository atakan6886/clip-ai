def safe_cpu_threads(pct: int) -> int:
    """Ð’Ð¾Ð·Ð²Ñ€Ð°Ñ‰Ð°ÐµÑ‚ ÐºÐ¾Ð»Ð¸Ñ‡ÐµÑÑ‚Ð²Ð¾ Ð¿Ð¾Ñ‚Ð¾ÐºÐ¾Ð² CPU â€” Ð¼Ð¸Ð½Ð¸Ð¼ÑƒÐ¼ 1, Ð¾ÑÑ‚Ð°Ð²Ð»ÑÐµÐ¼ Ñ…Ð¾Ñ‚Ñ Ð±Ñ‹ 1 ÑÐ´Ñ€Ð¾ ÑÐ¸ÑÑ‚ÐµÐ¼Ðµ."""
    total = get_cpu_count()
    if total <= 1:
        return 1
    count = max(1, min(total - 1, math.ceil(total * pct / 100)))
    return count

def apply_cpu_limit(threads: int) -> None:
