    def _analyze_motion_cpu(self, video_path: str, duration: float) -> np.ndarray:
        """CPU Ð¿ÑƒÑ‚ÑŒ Ð°Ð½Ð°Ð»Ð¸Ð·Ð° Ð´Ð²Ð¸Ð¶ÐµÐ½Ð¸Ñ Ñ‡ÐµÑ€ÐµÐ· Ð¿Ð¾Ð¿Ð°Ñ€Ð½Ð¾Ðµ ÑÑ€Ð°Ð²Ð½ÐµÐ½Ð¸Ðµ ÐºÐ°Ð´Ñ€Ð¾Ð²."""
        scores = np.zeros(int(duration))
        cap = None
        try:
            import cv2
            cap = cv2.VideoCapture(video_path)
            fps = cap.get(cv2.CAP_PROP_FPS) or 25
            if fps <= 1:
                fps = 25
            skip = max(Config.MOTION_SKIP_BASE, int(duration / Config.MOTION_ADAPT_DIV))
            if self.mode.get() == "balanced":
                skip = max(skip, int(skip * Config.BALANCED_MOTION_SKIP_MULT))
            prev, fi = None, 0
            _throttle_every = max(1, int(fps * 2))  # Ð¿Ñ€Ð¸Ð¼ÐµÑ€Ð½Ð¾ ÐºÐ°Ð¶Ð´Ñ‹Ðµ ~2 ÑÐµÐºÑƒÐ½Ð´Ñ‹ Ð²Ð¸Ð´ÐµÐ¾
            logger.info(f"ÐÐ½Ð°Ð»Ð¸Ð· Ð´Ð²Ð¸Ð¶ÐµÐ½Ð¸Ñ (CPU): skip={skip}, duration={duration:.0f}Ñ")
            while True:
                if self.stop_flag.is_set():
                    logger.info("ÐÐ½Ð°Ð»Ð¸Ð· Ð´Ð²Ð¸Ð¶ÐµÐ½Ð¸Ñ (CPU) Ð¿Ñ€ÐµÑ€Ð²Ð°Ð½ (stop_flag)")
