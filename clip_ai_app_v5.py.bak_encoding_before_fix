    def _process_split(self, video_path: str, t0: float) -> None:
        """ÐÐ°Ñ€ÐµÐ·ÐºÐ° Ð¿Ð¾ Ð²Ñ€ÐµÐ¼ÐµÐ½Ð¸ Ð±ÐµÐ· AI â€” Ð¿Ñ€Ð¾ÑÑ‚Ð¾ Ñ€ÐµÐ¶ÐµÑ‚ Ñ€Ð°Ð²Ð½Ñ‹Ð¼Ð¸ ÐºÑƒÑÐºÐ°Ð¼Ð¸."""
        try:
            out_folder = self.out_folder.get()
            clip_dur   = self.split_dur.get()
            duration   = self._get_duration(video_path)
            if duration == 0: raise RuntimeError("ÐÐµ ÑƒÐ´Ð°Ð»Ð¾ÑÑŒ Ð¾Ð¿Ñ€ÐµÐ´ÐµÐ»Ð¸Ñ‚ÑŒ Ð´Ð»Ð¸Ñ‚ÐµÐ»ÑŒÐ½Ð¾ÑÑ‚ÑŒ")
            self._safe_log(f"â±ï¸ {int(duration // 60)}:{int(duration % 60):02d}")

            starts = list(range(0, int(duration), clip_dur))
            if self.split_limit.get(): starts = starts[:self.num_clips.get()]

            os.makedirs(out_folder, exist_ok=True)
            base = os.path.splitext(os.path.basename(video_path))[0][:20]
            self._safe_log(f"âœ‚ï¸ ÐÐ°Ñ€ÐµÐ·Ð°ÑŽ {len(starts)} ÐºÐ»Ð¸Ð¿Ð¾Ð² Ð¿Ð¾ {clip_dur}Ñ...", "accent")
            logger.info(f"ÐÐ°Ñ€ÐµÐ·ÐºÐ° Ð¿Ð¾ Ð²Ñ€ÐµÐ¼ÐµÐ½Ð¸: {len(starts)} ÐºÐ»Ð¸Ð¿Ð¾Ð² Ð¿Ð¾ {clip_dur}Ñ")

            for i, s in enumerate(starts, 1):
                if self.stop_flag.is_set():
                    logger.info("ÐÐ°Ñ€ÐµÐ·ÐºÐ° Ð¿Ñ€ÐµÑ€Ð²Ð°Ð½Ð° Ð¿Ð¾Ð»ÑŒÐ·Ð¾Ð²Ð°Ñ‚ÐµÐ»ÐµÐ¼")
                    break
                if not self._wait_if_paused(): break
                e   = min(s + clip_dur, duration)
                out = os.path.join(out_folder, f"{base}_part_{i:03d}.mp4")
                self._safe_progress(
                    int(i / len(starts) * 100),
                    f"ÐšÐ»Ð¸Ð¿ {i}/{len(starts)} | {int(time.time() - t0)}Ñ")
                self._safe_log(
                    f"  [{i}/{len(starts)}] {int(s // 60):02d}:{int(s % 60):02d}"
                    f" â†’ {int(e // 60):02d}:{int(e % 60):02d}")
                self._ffmpeg_cut(video_path, s, e - s, out)
        except Exception as e:
            logger.exception(f"ÐžÑˆÐ¸Ð±ÐºÐ° Ð½Ð°Ñ€ÐµÐ·ÐºÐ¸ Ð¿Ð¾ Ð²Ñ€ÐµÐ¼ÐµÐ½Ð¸: {e}")
