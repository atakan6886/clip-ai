def apply_cpu_affinity(threads: int) -> None:
    """
    ÐžÐ³Ñ€Ð°Ð½Ð¸Ñ‡Ð¸Ð²Ð°ÐµÐ¼ Ð¿Ñ€Ð¾Ñ†ÐµÑÑ ÐºÐ¾Ð½ÐºÑ€ÐµÑ‚Ð½Ñ‹Ð¼ Ñ‡Ð¸ÑÐ»Ð¾Ð¼ ÑÐ´ÐµÑ€ Ñ‡ÐµÑ€ÐµÐ· cpu_affinity.
    Ð­Ñ‚Ð¾ Ñ€ÐµÐ°Ð»ÑŒÐ½Ð¾ Ñ€Ð°Ð±Ð¾Ñ‚Ð°ÐµÑ‚ â€” Ð² Ð¾Ñ‚Ð»Ð¸Ñ‡Ð¸Ðµ Ð¾Ñ‚ OMP_NUM_THREADS ÐºÐ¾Ñ‚Ð¾Ñ€Ñ‹Ð¹ FFmpeg Ð¸Ð³Ð½Ð¾Ñ€Ð¸Ñ€ÑƒÐµÑ‚.
    """
    try:
        import psutil
        p      = psutil.Process()
        total  = get_cpu_count()
        count  = max(1, min(threads, total))
        # Ð‘ÐµÑ€Ñ‘Ð¼ Ð¿ÐµÑ€Ð²Ñ‹Ðµ N ÑÐ´ÐµÑ€
        cores  = list(range(total))[:count]
        p.cpu_affinity(cores)
        logger.info(f"CPU affinity: {count} Ð¸Ð· {total} ÑÐ´ÐµÑ€ ({cores})")
    except AttributeError:
        # cpu_affinity Ð½Ðµ Ð¿Ð¾Ð´Ð´ÐµÑ€Ð¶Ð¸Ð²Ð°ÐµÑ‚ÑÑ Ð½Ð° ÑÑ‚Ð¾Ð¹ Ð¿Ð»Ð°Ñ‚Ñ„Ð¾Ñ€Ð¼Ðµ
        logger.debug("cpu_affinity Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½ â€” Ð¸ÑÐ¿Ð¾Ð»ÑŒÐ·ÑƒÐµÐ¼ Ñ‚Ð¾Ð»ÑŒÐºÐ¾ OMP_NUM_THREADS")
    except Exception as e:
        logger.debug(f"cpu_affinity Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}")

