    def _build_ffmpeg_cut_cmd(
        self,
        video_path: str,
        start: float,
        duration_sec: float,
        out_path: str,
        backend: str
    ) -> List[str]:
        """Ð¡Ð¾Ð±Ð¸Ñ€Ð°ÐµÑ‚ ÐºÐ¾Ð¼Ð°Ð½Ð´Ñƒ FFmpeg Ð´Ð»Ñ Ð½Ð°Ñ€ÐµÐ·ÐºÐ¸ ÐºÐ»Ð¸Ð¿Ð° Ñ Ð²Ñ‹Ð±Ñ€Ð°Ð½Ð½Ñ‹Ð¼ CPU/GPU backend ÑÑ„Ñ„ÐµÐºÑ‚Ð¾Ð²."""
        vf = self._build_vf()
        speed = self.speed_val.get()
        threads = str(max(1, self.cpu_threads.get()))

        cmd = [
            FFMPEG, "-y",
            "-threads", threads,      # Ð¾Ð±Ñ‰Ð¸Ð¹ Ð»Ð¸Ð¼Ð¸Ñ‚ Ð¿Ð¾Ñ‚Ð¾ÐºÐ¾Ð² FFmpeg
            "-ss", str(start),
            "-i", video_path,
            "-t", str(duration_sec)
        ]
        if vf:
            cmd += ["-vf", vf]

        af_parts = []
        if speed != "1x":
            sp = {"0.5x": 0.5, "1.5x": 1.5, "2x": 2.0}.get(speed, 1.0)
            if sp > 2.0:
                af_parts += ["atempo=2.0", f"atempo={sp/2.0:.2f}"]
            elif sp < 0.5:
                af_parts += ["atempo=0.5", f"atempo={sp*2.0:.2f}"]
            else:
                af_parts.append(f"atempo={sp:.2f}")
        if af_parts:
            cmd += ["-af", ",".join(af_parts)]

        if backend == "gpu":
            cmd += [
                "-c:v", "h264_nvenc",
                "-preset", "p5",
                "-c:a", "aac",
            ]
        else:
            cmd += [
                "-c:v", "libx264",
                "-threads", threads,   # Ð¾Ñ‚Ð´ÐµÐ»ÑŒÐ½Ñ‹Ð¹ Ð»Ð¸Ð¼Ð¸Ñ‚ Ð¿Ð¾Ñ‚Ð¾ÐºÐ¾Ð² x264
                "-c:a", "aac",
            ]

        cmd += [
            "-map", "0:v:0", "-map", "0:a:0?",
            "-avoid_negative_ts", "1", out_path
        ]
        return cmd

    def _run_ffmpeg(self, cmd: List[str], timeout: int = Config.FFMPEG_TIMEOUT,
                    retries: int = 1) -> Optional[subprocess.CompletedProcess]:
        """
        Ð—Ð°Ð¿ÑƒÑÐºÐ°ÐµÑ‚ ffmpeg Ñ Ñ‚Ð°Ð¹Ð¼Ð°ÑƒÑ‚Ð¾Ð¼, Ð»Ð¾Ð³Ð¸Ñ€Ð¾Ð²Ð°Ð½Ð¸ÐµÐ¼ Ð¸ retry.
        retries=1 Ð¾Ð·Ð½Ð°Ñ‡Ð°ÐµÑ‚: 1 Ð¿Ð¾Ð¿Ñ‹Ñ‚ÐºÐ° + 1 Ð¿Ð¾Ð²Ñ‚Ð¾Ñ€ = 2 Ð¿Ð¾Ð¿Ñ‹Ñ‚ÐºÐ¸ Ð²ÑÐµÐ³Ð¾.
        """
        logger.debug(f"FFmpeg ÐºÐ¾Ð¼Ð°Ð½Ð´Ð°: {' '.join(cmd[:6])}...")

        def _attempt():
            result = subprocess.run(
                cmd, capture_output=True,
                creationflags=NO_WINDOW,
                timeout=timeout)
            if result.returncode != 0:
                err = result.stderr.decode(errors="ignore")[:200]
                logger.warning(f"FFmpeg ÐºÐ¾Ð´ {result.returncode}: {err}")
                raise FFmpegError(f"FFmpeg Ð²ÐµÑ€Ð½ÑƒÐ» ÐºÐ¾Ð´ {result.returncode}: {err[:80]}")
            return result

        try:
            return with_retry(_attempt, retries=retries, delay=2.0,
                              error_cls=FFmpegError, context="FFmpeg")
        except FFmpegError as e:
            self._safe_log(f"âš ï¸ {e}", "error")
            return None
        except subprocess.TimeoutExpired:
            msg = f"âš ï¸ FFmpeg Ñ‚Ð°Ð¹Ð¼Ð°ÑƒÑ‚ ({timeout}Ñ) â€” Ð¿Ñ€Ð¾Ð¿ÑƒÑÐºÐ°ÑŽ"
            self._safe_log(msg, "error")
            logger.error(msg)
            return None
        except Exception as e:
            err = handle_error(e, "FFmpeg")
            self._safe_log(f"âš ï¸ FFmpeg: {err}", "error")
            return None

    def _ffmpeg_cut(self, video_path: str, start: float, duration_sec: float, out_path: str) -> None:
        """ÐÐ°Ñ€ÐµÐ·Ð°ÐµÑ‚ Ð¾Ð´Ð¸Ð½ ÐºÐ»Ð¸Ð¿ Ñ Ð¿Ñ€Ð¸Ð¼ÐµÐ½ÐµÐ½Ð¸ÐµÐ¼ Ð²ÑÐµÑ… ÑÑ„Ñ„ÐµÐºÑ‚Ð¾Ð² Ð¸ Ð¾Ð³Ñ€Ð°Ð½Ð¸Ñ‡ÐµÐ½Ð¸ÐµÐ¼ Ð¿Ð¾Ñ‚Ð¾ÐºÐ¾Ð²."""
