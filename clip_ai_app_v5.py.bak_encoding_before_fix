    def _process_queue(self) -> None:
        total = len(self.video_paths); t0 = time.time()
        logger.info(f"ÐÐ°Ñ‡Ð¸Ð½Ð°ÑŽ Ð¾Ð±Ñ€Ð°Ð±Ð¾Ñ‚ÐºÑƒ Ð¾Ñ‡ÐµÑ€ÐµÐ´Ð¸: {total} Ð²Ð¸Ð´ÐµÐ¾")
        try:
            for idx, vp in enumerate(self.video_paths):
                if self.stop_flag.is_set():
                    logger.info("ÐžÐ±Ñ€Ð°Ð±Ð¾Ñ‚ÐºÐ° Ð¿Ñ€ÐµÑ€Ð²Ð°Ð½Ð° Ð¿Ð¾Ð»ÑŒÐ·Ð¾Ð²Ð°Ñ‚ÐµÐ»ÐµÐ¼")
                    break
                self._safe_log(f"\n Ð’Ð¸Ð´ÐµÐ¾ {idx + 1}/{total}: {os.path.basename(vp)}", "accent")
                logger.info(f"ÐžÐ±Ñ€Ð°Ð±Ð°Ñ‚Ñ‹Ð²Ð°ÑŽ [{idx+1}/{total}]: {vp}")
                mode = self.mode.get()
                if mode == "split":
                    self._process_split(vp, t0)
                elif mode == "hybrid":
                    self._process_hybrid(vp, t0)
                else:
                    self._process_one(vp, t0)
                GPU.clear_vram()
                self._throttle()
        except Exception as e:
            logger.exception(f"ÐšÑ€Ð¸Ñ‚Ð¸Ñ‡ÐµÑÐºÐ°Ñ Ð¾ÑˆÐ¸Ð±ÐºÐ° Ð² Ð¾Ñ‡ÐµÑ€ÐµÐ´Ð¸: {e}")
            self._safe_log(f"âŒ ÐšÑ€Ð¸Ñ‚Ð¸Ñ‡ÐµÑÐºÐ°Ñ Ð¾ÑˆÐ¸Ð±ÐºÐ°: {e}", "error")
        finally:
            elapsed = int(time.time() - t0)
            interrupted = self.stop_flag.is_set()
            if interrupted:
                self._safe_progress(0, f"ÐžÑÑ‚Ð°Ð½Ð¾Ð²Ð»ÐµÐ½Ð¾ Ñ‡ÐµÑ€ÐµÐ· {elapsed}Ñ")
                self._safe_log(f"\nâ¹ ÐžÑÑ‚Ð°Ð½Ð¾Ð²Ð»ÐµÐ½Ð¾ Ð¿Ð¾Ð»ÑŒÐ·Ð¾Ð²Ð°Ñ‚ÐµÐ»ÐµÐ¼ Ñ‡ÐµÑ€ÐµÐ· {elapsed}Ñ", "warn")
                logger.info(f"ÐžÑ‡ÐµÑ€ÐµÐ´ÑŒ Ð¾ÑÑ‚Ð°Ð½Ð¾Ð²Ð»ÐµÐ½Ð° Ð¿Ð¾Ð»ÑŒÐ·Ð¾Ð²Ð°Ñ‚ÐµÐ»ÐµÐ¼ Ñ‡ÐµÑ€ÐµÐ· {elapsed}Ñ")
            else:
                self._safe_progress(100, f"Ð“Ð¾Ñ‚Ð¾Ð²Ð¾ Ð·Ð° {elapsed}Ñ")
                self._safe_log(f"\nâœ… Ð“Ð¾Ñ‚Ð¾Ð²Ð¾! {total} Ð²Ð¸Ð´ÐµÐ¾ Ð·Ð° {elapsed}Ñ", "success")
                logger.info(f"ÐžÑ‡ÐµÑ€ÐµÐ´ÑŒ Ð·Ð°Ð²ÐµÑ€ÑˆÐµÐ½Ð° Ð·Ð° {elapsed}Ñ")
            self._set_state(AppState.IDLE)
            if not interrupted:
                self.after(0, lambda: open_folder(self.out_folder.get()))
            self.after(0, lambda: self.btn_run.configure(
                state="normal", bg=RED, text="â–¶   Ð—ÐÐŸÐ£Ð¡Ð¢Ð˜Ð¢Ð¬ ÐÐÐ Ð•Ð—ÐšÐ£"))
            self.after(0, lambda: self.btn_pause.configure(state="disabled"))

