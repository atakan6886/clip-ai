    def _process_hybrid(self, video_path, t0):
        """CPU + GPU Ñ€Ð°Ð±Ð¾Ñ‚Ð°ÑŽÑ‚ Ð¿Ð°Ñ€Ð°Ð»Ð»ÐµÐ»ÑŒÐ½Ð¾ Ð² Ð¾Ñ‚Ð´ÐµÐ»ÑŒÐ½Ñ‹Ñ… Ð¿Ð¾Ñ‚Ð¾ÐºÐ°Ñ…."""
        tmp_audio = None
        try:
            duration = self._get_duration(video_path)
            if duration == 0: raise Exception("ÐÐµ ÑƒÐ´Ð°Ð»Ð¾ÑÑŒ Ð¾Ð¿Ñ€ÐµÐ´ÐµÐ»Ð¸Ñ‚ÑŒ Ð´Ð»Ð¸Ñ‚ÐµÐ»ÑŒÐ½Ð¾ÑÑ‚ÑŒ")
            self._safe_log(
                f"â±ï¸ {int(duration // 60)}:{int(duration % 60):02d} â€” Ð“Ð¸Ð±Ñ€Ð¸Ð´ Ñ€ÐµÐ¶Ð¸Ð¼")

            self._safe_progress(5, "Ð˜Ð·Ð²Ð»ÐµÐºÐ°ÑŽ Ð°ÑƒÐ´Ð¸Ð¾...")
            tmp_audio = self._extract_audio(video_path)
            energy    = self._calc_energy(tmp_audio, duration)
            ns        = int(duration)

            cpu_res = {}; gpu_res = {}
            motion_gpu = self._is_motion_gpu_enabled()

            def cpu_worker():
