    def _download_yt(self):
        url = self.yt_url.get().strip()
        if not url or url == "https://youtube.com/watch?v=...":
            messagebox.showerror("ÐžÑˆÐ¸Ð±ÐºÐ°", "Ð’ÑÑ‚Ð°Ð²ÑŒ ÑÑÑ‹Ð»ÐºÑƒ!"); return
