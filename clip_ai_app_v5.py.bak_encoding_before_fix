import queue as queue_module

class WorkerEvent:
    """Ð¡Ð¾Ð±Ñ‹Ñ‚Ð¸Ðµ Ð¾Ñ‚ worker Ðº UI â€” Ð½Ðµ Ñ‚Ñ€Ð¾Ð³Ð°ÐµÐ¼ tkinter Ð¸Ð· Ð¿Ð¾Ñ‚Ð¾ÐºÐ°."""
    LOG      = "log"
    PROGRESS = "progress"
    DONE     = "done"
    ERROR    = "error"

    def __init__(self, kind: str, data: dict):
        self.kind = kind
        self.data = data

class VideoWorker:
    """
    Ð˜Ð·Ð¾Ð»Ð¸Ñ€Ð¾Ð²Ð°Ð½Ð½Ñ‹Ð¹ worker Ð´Ð»Ñ Ð¾Ð±Ñ€Ð°Ð±Ð¾Ñ‚ÐºÐ¸ Ð²Ð¸Ð´ÐµÐ¾.
    UI Ð¿Ð¾Ð´Ð¿Ð¸ÑÑ‹Ð²Ð°ÐµÑ‚ÑÑ Ð½Ð° ÑÐ¾Ð±Ñ‹Ñ‚Ð¸Ñ Ñ‡ÐµÑ€ÐµÐ· callback â€” Ð½ÐµÑ‚ Ð¿Ñ€ÑÐ¼Ñ‹Ñ… Ð²Ñ‹Ð·Ð¾Ð²Ð¾Ð² tkinter Ð¸Ð· Ð¿Ð¾Ñ‚Ð¾ÐºÐ°.
    Ð—Ð°Ð´Ð°Ñ‡Ð¸ Ð¿Ñ€Ð¸Ñ…Ð¾Ð´ÑÑ‚ Ñ‡ÐµÑ€ÐµÐ· queue.Queue â€” Ð¼Ð¾Ð¶Ð½Ð¾ Ð´Ð¾Ð±Ð°Ð²Ð»ÑÑ‚ÑŒ Ð½Ð° Ð»ÐµÑ‚Ñƒ.
    """

    def __init__(self, on_event: Callable[[WorkerEvent], None]):
        self._task_queue  : queue_module.Queue = queue_module.Queue()
        self._stop_flag   = threading.Event()
        self._pause_event = threading.Event()
        self._pause_event.set()
        self._on_event    = on_event
        self._thread      : Optional[threading.Thread] = None
        self._state_lock  = threading.Lock()

    def submit(self, fn: Callable, *args, **kwargs) -> None:
        """Ð”Ð¾Ð±Ð°Ð²Ð¸Ñ‚ÑŒ Ð·Ð°Ð´Ð°Ñ‡Ñƒ Ð² Ð¾Ñ‡ÐµÑ€ÐµÐ´ÑŒ."""
        self._task_queue.put((fn, args, kwargs))

    def start(self) -> None:
        """Ð—Ð°Ð¿ÑƒÑÑ‚Ð¸Ñ‚ÑŒ worker Ð¿Ð¾Ñ‚Ð¾Ðº. Ð—Ð°Ñ‰Ð¸Ñ‚Ð° Ð¾Ñ‚ Ð´Ð²Ð¾Ð¹Ð½Ð¾Ð³Ð¾ Ð·Ð°Ð¿ÑƒÑÐºÐ°."""
        if self._thread and self._thread.is_alive():
            logger.warning("VideoWorker ÑƒÐ¶Ðµ Ð·Ð°Ð¿ÑƒÑ‰ÐµÐ½ â€” Ð¿Ñ€Ð¾Ð¿ÑƒÑÐºÐ°ÐµÐ¼ Ð¿Ð¾Ð²Ñ‚Ð¾Ñ€Ð½Ñ‹Ð¹ ÑÑ‚Ð°Ñ€Ñ‚")
            return
        self._stop_flag.clear()
        self._pause_event.set()
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        logger.info("VideoWorker Ð·Ð°Ð¿ÑƒÑ‰ÐµÐ½")

    def stop(self) -> None:
        """ÐžÑÑ‚Ð°Ð½Ð¾Ð²Ð¸Ñ‚ÑŒ worker â€” Ð´Ð¾Ð¶Ð´Ð°Ñ‚ÑŒÑÑ Ð·Ð°Ð²ÐµÑ€ÑˆÐµÐ½Ð¸Ñ Ñ‚ÐµÐºÑƒÑ‰ÐµÐ¹ Ð·Ð°Ð´Ð°Ñ‡Ð¸."""
        self._stop_flag.set()
        self._pause_event.set()  # Ñ€Ð°Ð·Ð±Ð»Ð¾ÐºÐ¸Ñ€ÑƒÐµÐ¼ ÐµÑÐ»Ð¸ Ð½Ð° Ð¿Ð°ÑƒÐ·Ðµ
        self._task_queue.put(None)  # sentinel â€” Ð²Ñ‹Ñ…Ð¾Ð´ Ð¸Ð· Ñ†Ð¸ÐºÐ»Ð°
        logger.info("VideoWorker: ÑÐ¸Ð³Ð½Ð°Ð» Ð¾ÑÑ‚Ð°Ð½Ð¾Ð²ÐºÐ¸")

    def pause(self) -> None:
        self._pause_event.clear()
        logger.info("VideoWorker: Ð¿Ð°ÑƒÐ·Ð°")

    def resume(self) -> None:
        self._pause_event.set()
        logger.info("VideoWorker: Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶ÐµÐ½Ð¸Ðµ")

    def is_stopped(self) -> bool:
        return self._stop_flag.is_set()

    def wait_if_paused(self) -> bool:
        """Ð–Ð´Ñ‘Ð¼ ÐµÑÐ»Ð¸ Ð½Ð° Ð¿Ð°ÑƒÐ·Ðµ. Ð’Ð¾Ð·Ð²Ñ€Ð°Ñ‰Ð°ÐµÑ‚ False ÐµÑÐ»Ð¸ Ð½ÑƒÐ¶Ð½Ð¾ Ð¾ÑÑ‚Ð°Ð½Ð¾Ð²Ð¸Ñ‚ÑŒÑÑ."""
        while not self._pause_event.is_set():
            if self._stop_flag.is_set():
                return False
            time.sleep(0.1)
        return not self._stop_flag.is_set()

    def emit(self, kind: str, **data) -> None:
        """ÐžÑ‚Ð¿Ñ€Ð°Ð²Ð¸Ñ‚ÑŒ ÑÐ¾Ð±Ñ‹Ñ‚Ð¸Ðµ Ð² UI Ð¿Ð¾Ñ‚Ð¾Ðº."""
        self._on_event(WorkerEvent(kind, data))

    def _throttle_cpu(self) -> None:
        """
        Runtime throttle Ð¿Ð¾ CPU%.
        Ð–Ð´Ñ‘Ð¼ Ð¿Ð¾ÐºÐ° CPU Ð½Ðµ Ð¾Ð¿ÑƒÑÑ‚Ð¸Ñ‚ÑÑ Ð½Ð¸Ð¶Ðµ 75% â€” Ð´Ð°Ñ‘Ð¼ ÑÐ¸ÑÑ‚ÐµÐ¼Ðµ Ð´Ñ‹ÑˆÐ°Ñ‚ÑŒ.
        Ð’Ñ‹Ð·Ñ‹Ð²Ð°ÐµÑ‚ÑÑ Ð¿ÐµÑ€ÐµÐ´ ÐºÐ°Ð¶Ð´Ð¾Ð¹ Ð·Ð°Ð´Ð°Ñ‡ÐµÐ¹ Ð¸ Ð²Ð½ÑƒÑ‚Ñ€Ð¸ Ñ‚ÑÐ¶Ñ‘Ð»Ñ‹Ñ… Ð¾Ð¿ÐµÑ€Ð°Ñ†Ð¸Ð¹.
        """
        try:
            import psutil
            while not self._stop_flag.is_set():
                cpu = psutil.cpu_percent(interval=0.5)
                if cpu < 75:
                    break
                logger.debug(f"Worker throttle: CPU {cpu:.0f}% â€” Ð¶Ð´Ñ‘Ð¼...")
                time.sleep(0.5)
        except Exception:
            pass  # psutil Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿ÐµÐ½ â€” Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶Ð°ÐµÐ¼ Ð±ÐµÐ· throttle

    def _throttle_temp(self, max_temp: int = 85) -> None:
        """
        Runtime throttle Ð¿Ð¾ Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ðµ CPU.
        Ð–Ð´Ñ‘Ð¼ Ð¿Ð¾ÐºÐ° Ñ‚ÐµÐ¼Ð¿ÐµÑ€Ð°Ñ‚ÑƒÑ€Ð° Ð½Ðµ ÑƒÐ¿Ð°Ð´Ñ‘Ñ‚ Ð½Ð¸Ð¶Ðµ max_temp.
        """
        try:
            import psutil
            while not self._stop_flag.is_set():
                temps = psutil.sensors_temperatures()
                if not temps:
                    break
                entries = temps.get("coretemp") or temps.get("k10temp") or []
                if not entries:
                    break
                current = max(t.current for t in entries)
                if current <= max_temp:
                    break
                logger.debug(f"Worker temp throttle: CPU {current:.0f}Â°C > {max_temp}Â°C â€” Ð¶Ð´Ñ‘Ð¼...")
                time.sleep(1.0)
        except Exception:
            pass  # sensors Ð½ÐµÐ´Ð¾ÑÑ‚ÑƒÐ¿Ð½Ñ‹ â€” Ð¿Ñ€Ð¾Ð´Ð¾Ð»Ð¶Ð°ÐµÐ¼

    def _run(self) -> None:
        """ÐžÑÐ½Ð¾Ð²Ð½Ð¾Ð¹ Ñ†Ð¸ÐºÐ» worker â€” Ð±ÐµÑ€Ñ‘Ñ‚ Ð·Ð°Ð´Ð°Ñ‡Ð¸ Ð¸Ð· Ð¾Ñ‡ÐµÑ€ÐµÐ´Ð¸ Ñ runtime ÐºÐ¾Ð½Ñ‚Ñ€Ð¾Ð»ÐµÐ¼."""
        logger.info("VideoWorker: Ñ†Ð¸ÐºÐ» Ð·Ð°Ð¿ÑƒÑ‰ÐµÐ½")
        while not self._stop_flag.is_set():
            try:
                item = self._task_queue.get(timeout=1.0)
                if item is None:  # sentinel
                    break
                fn, args, kwargs = item
                try:
                    # â”€â”€ Runtime ÐºÐ¾Ð½Ñ‚Ñ€Ð¾Ð»ÑŒ ÐŸÐ•Ð Ð•Ð” Ð·Ð°Ð´Ð°Ñ‡ÐµÐ¹ â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    self._throttle_cpu()   # Ð¶Ð´Ñ‘Ð¼ ÐµÑÐ»Ð¸ CPU > 75%
                    self._throttle_temp()  # Ð¶Ð´Ñ‘Ð¼ ÐµÑÐ»Ð¸ CPU temp > 85Â°C
                    # â”€â”€ Ð’Ñ‹Ð¿Ð¾Ð»Ð½ÑÐµÐ¼ Ð·Ð°Ð´Ð°Ñ‡Ñƒ â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    fn(*args, **kwargs)
                except AppError as e:
                    logger.error(f"VideoWorker Ð·Ð°Ð´Ð°Ñ‡Ð° AppError: {e}")
                    self.emit(WorkerEvent.ERROR, message=str(e), recoverable=e.recoverable)
                except Exception as e:
                    err = handle_error(e, "VideoWorker._run")
                    self.emit(WorkerEvent.ERROR, message=str(err), recoverable=True)
                finally:
                    # Ð“Ð°Ñ€Ð°Ð½Ñ‚Ð¸Ñ€Ð¾Ð²Ð°Ð½Ð½Ñ‹Ð¹ cleanup Ð¿Ð¾ÑÐ»Ðµ ÐºÐ°Ð¶Ð´Ð¾Ð¹ Ð·Ð°Ð´Ð°Ñ‡Ð¸
                    try:
                        import gc; gc.collect()
                        try:
                            import torch
                            if torch.cuda.is_available():
                                torch.cuda.empty_cache()
                        except Exception:
                            pass
                    except Exception:
                        pass
                    self._task_queue.task_done()
            except queue_module.Empty:
                continue
