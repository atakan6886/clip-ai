            self._safe_log(f"âš ï¸ Ð”Ð²Ð¸Ð¶ÐµÐ½Ð¸Ðµ (CPU): {e}", "error")
        finally:
            if cap is not None:
                try:
                    cap.release()
                except Exception:
                    pass
        return scores

