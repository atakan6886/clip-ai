    def _cut_clips(self, score: np.ndarray, video_path: str, duration: float, ns: int, t0: float) -> None:
        """ÐÐ°Ñ…Ð¾Ð´Ð¸Ñ‚ Ð»ÑƒÑ‡ÑˆÐ¸Ðµ Ð¼Ð¾Ð¼ÐµÐ½Ñ‚Ñ‹ Ð¿Ð¾ score Ð¸ Ð½Ð°Ñ€ÐµÐ·Ð°ÐµÑ‚ ÐºÐ»Ð¸Ð¿Ñ‹."""
        num_clips  = self.num_clips.get()
        min_dur    = self.min_dur.get()
        max_dur    = self.max_dur.get()
        out_folder = self.out_folder.get()

        self._safe_progress(70, f"Ð˜Ñ‰Ñƒ Ð»ÑƒÑ‡ÑˆÐ¸Ðµ Ð¼Ð¾Ð¼ÐµÐ½Ñ‚Ñ‹... {int(time.time() - t0)}Ñ")
        score = np.clip(score / max(np.max(score), 1), 0, 1)
        score = smooth(score, k=5)

        if np.max(score) == 0:
            logger.warning("Score Ð¿ÑƒÑÑ‚Ð¾Ð¹ â€” Ð½Ð°Ñ€ÐµÐ·Ð°ÑŽ Ñ€Ð°Ð²Ð½Ð¾Ð¼ÐµÑ€Ð½Ð¾")
            cl = (min_dur + max_dur) // 2
            selected = [(s, s + cl) for s in range(0, ns - cl, max(cl, MIN_GAP + 1))][:num_clips]
        else:
            windows = []
            for s in range(ns):
                cl = int(np.random.randint(min_dur, max_dur + 1))
                e  = s + cl
                if e > ns: break
                seg = score[s:e]
                windows.append((s, e, float(np.mean(seg) * 0.5 + np.max(seg) * 0.5)))
            windows.sort(key=lambda x: x[2], reverse=True)
            selected = []
            for s, e, _ in windows:
                if not any(not (e + MIN_GAP <= ss or s - MIN_GAP >= ee) for ss, ee in selected):
                    selected.append((s, e))
                if len(selected) >= num_clips: break
            selected.sort()
            logger.info(f"ÐÐ°Ð¹Ð´ÐµÐ½Ð¾ {len(selected)} Ð¼Ð¾Ð¼ÐµÐ½Ñ‚Ð¾Ð² Ð¸Ð· {num_clips} Ð·Ð°Ð¿Ñ€Ð¾ÑˆÐµÐ½Ð½Ñ‹Ñ…")

        if not selected:
            self._safe_log("âš ï¸ ÐÐµ Ð½Ð°Ð¹Ð´ÐµÐ½Ð¾ Ð¼Ð¾Ð¼ÐµÐ½Ñ‚Ð¾Ð².", "error")
            logger.warning("ÐÐµ Ð½Ð°Ð¹Ð´ÐµÐ½Ð¾ Ð½Ð¸ Ð¾Ð´Ð½Ð¾Ð³Ð¾ Ð¼Ð¾Ð¼ÐµÐ½Ñ‚Ð° Ð´Ð»Ñ Ð½Ð°Ñ€ÐµÐ·ÐºÐ¸")
            return

        os.makedirs(out_folder, exist_ok=True)
        base = os.path.splitext(os.path.basename(video_path))[0][:20]
        self._safe_log(f"âœ‚ï¸ ÐÐ°Ñ€ÐµÐ·Ð°ÑŽ {len(selected)} ÐºÐ»Ð¸Ð¿Ð¾Ð²...", "accent")

        for i, (s, e) in enumerate(selected, 1):
            if self.stop_flag.is_set():
                logger.info("ÐÐ°Ñ€ÐµÐ·ÐºÐ° Ð¿Ñ€ÐµÑ€Ð²Ð°Ð½Ð° Ð¿Ð¾Ð»ÑŒÐ·Ð¾Ð²Ð°Ñ‚ÐµÐ»ÐµÐ¼")
                break
            if not self._wait_if_paused(): break
            self._check_and_wait_temp()
            e   = min(e, duration)
            out = os.path.join(out_folder, f"{base}_clip_{i:02d}.mp4")
            self._safe_progress(
                70 + int(i / len(selected) * 28),
                f"ÐšÐ»Ð¸Ð¿ {i}/{len(selected)} | {int(time.time() - t0)}Ñ")
            self._safe_log(
                f"  [{i}/{len(selected)}] "
                f"{int(s // 60):02d}:{int(s % 60):02d} â†’ {int(e // 60):02d}:{int(e % 60):02d}")
            logger.info(f"ÐšÐ»Ð¸Ð¿ {i}: {s:.0f}Ñ â†’ {e:.0f}Ñ â†’ {out}")
            self._ffmpeg_cut(video_path, s, e - s, out)
            self._throttle()

